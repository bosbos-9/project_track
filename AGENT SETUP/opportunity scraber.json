    {
      "parameters": {
        "jsCode": "const qwenItems = $input.all();\nconst sourceItems = $('Fetch info from DB').all();\n\nfunction extractJson(content) {\n  if (!content) {\n    throw new Error(\"Qwen content is empty\");\n  }\n\n  // Remove markdown json block if Qwen returns ```json ... ```\n  content = content\n    .replace(/```json/gi, \"\")\n    .replace(/```/g, \"\")\n    .trim();\n\n  const match = content.match(/\\{[\\s\\S]*\\}/);\n\n  if (!match) {\n    throw new Error(\"No JSON object found in Qwen response: \" + content);\n  }\n\n  return JSON.parse(match[0]);\n}\n\nfunction normalizeScore(value) {\n  if (value === null || value === undefined) return 0;\n\n  let num = Number(value);\n\n  if (Number.isNaN(num)) return 0;\n\n  // Qwen sometimes returns 0.95 instead of 95\n  if (num > 0 && num <= 1) {\n    num = num * 100;\n  }\n\n  return Math.round(num);\n}\n\nreturn qwenItems.map((item, index) => {\n  const source = sourceItems[index].json;\n  const content = item.json.choices?.[0]?.message?.content;\n\n  const parsed = extractJson(content);\n\n  return {\n  json: {\n    reference_number: source.reference_number,\n    source: source.source,\n\n    decision: parsed.decision || \"REVIEW\",\n    fit_score: normalizeScore(parsed.fit_score),\n    confidence: normalizeScore(parsed.confidence),\n\n    best_service_area: parsed.best_service_area || null,\n    matched_service_areas: parsed.matched_service_areas || [],\n\n    reason_ar: parsed.reason_ar || null,\n    recommended_action: parsed.recommended_action || null,\n\n    model: item.json.model || \"qwen3.6-flash\",\n    raw_ai_response: parsed\n  }\n};\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1008,
        -144
      ],
